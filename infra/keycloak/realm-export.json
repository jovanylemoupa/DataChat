{
  "realm": "datachat",
  "enabled": true,
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "clients": [
    {
      "clientId": "datachat-frontend",
      "enabled": true,
      "publicClient": true,
      "redirectUris": ["http://localhost:4200/*"],
      "webOrigins": ["http://localhost:4200"],
      "standardFlowEnabled": true
    },
    {
      "clientId": "datachat-backend",
      "enabled": true,
      "secret": "change-me",
      "bearerOnly": true
    }
  ],
  "roles": {
    "realm": [
      { "name": "user" },
      { "name": "admin" }
    ]
  },
  "defaultRoles": ["user"]
}
